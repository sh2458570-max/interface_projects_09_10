{
  "version": "1.0",
  "project_name": "demo_simple",
  "runtime": {
    "loop_sleep_ms": 2,
    "check_data_interval_ms": 5000,
    "endpoints": [
      {
        "ip": "127.0.0.1",
        "port": 3333,
        "type": "udp",
        "recv": 1,
        "feed_back_port": 3333,
        "name": "Temp_Sensor"
      },
      {
        "ip": "127.0.0.1",
        "port": 3336,
        "type": "udp",
        "recv": 0,
        "feed_back_port": 3333,
        "name": "Temp_Report"
      }
    ]
  },
  "conversions": [
    {
      "name": "TempSensorToTempReport",
      "mode": "simple",
      "sources": [
        {
          "alias": "sensor",
          "protocol": "Temp_Sensor"
        }
      ],
      "target": {
        "protocol": "Temp_Report"
      },
      "runtime": {
        "process_method": "TempReportDataPro",
        "response_enabled": true,
        "sources": [
          {
            "alias": "sensor",
            "message_name": "Temp_Sensor",
            "display_name": "Temp.Sensor",
            "fetches": [
              {"count": 1, "cycle_ms": 0}
            ]
          }
        ]
      },
      "rules": [
        {
          "target_field": "temperature_c",
          "formula": "sensor.temperature",
          "source_fields": ["sensor.temperature"],
          "rule_type": "direct",
          "when": null,
          "default_value": null,
          "description": "温度直接映射"
        },
        {
          "target_field": "alarm",
          "formula": "sensor.temperature > 80 ? 1 : 0",
          "source_fields": ["sensor.temperature"],
          "rule_type": "conditional",
          "when": null,
          "default_value": 0,
          "description": "高温告警"
        }
      ]
    }
  ]
}
